NODE_ENV=production

# Database
DATABASE_URL=postgresql://botlogger:strong_password@postgres:5432/botlogger
POSTGRES_DB=botlogger
POSTGRES_USER=botlogger
POSTGRES_PASSWORD=strong_password

# Bots - no longer needed, managed via admin panel
# BOT_TOKENS=123456:AAA,234567:BBB,345678:CCC

# Auto-reply - no longer needed
# AUTO_REPLY_MESSAGE=Бот сейчас в разработке. Пожалуйста, приходите позже.

DROP_PENDING_UPDATES=true
LOG_LEVEL=info

# Administrators
ADMIN_TG_IDS=123456789,987654321  # TG IDs of administrators (comma-separated)
ADMIN_SESSION_SECRET=your_random_secret_key_for_sessions
ADMIN_SESSION_MAX_AGE_HOURS=24

# AI/LLM Configuration
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-chat

# STT Configuration
# MUXLISA (Uzbek)
MUXLISA_BASE_URL=https://service.muxlisa.uz
MUXLISA_API_KEY=your_muxlisa_api_key
MUXLISA_STT_TIMEOUT_MS=60000
MUXLISA_TTS_TIMEOUT_MS=60000
MUXLISA_MAX_AUDIO_SIZE_MB=5
MUXLISA_MAX_AUDIO_DURATION_SEC=60
MUXLISA_TTS_MAX_CHARS=1512
MUXLISA_TTS_SPEAKER=0

# OpenAI STT (Russian/English)
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_API_KEY=your_openai_api_key

# STT Fallback Settings
STT_FALLBACK_CONFIDENCE_THRESHOLD=0.7
STT_MAX_RETRIES=2

# Telegram admin chat for leads
ADMIN_CHAT_ID=-1001234567890

# AI Agent Settings
AGENT_MAX_CONVERSATION_TURNS=50
AGENT_INACTIVITY_TIMEOUT_MINUTES=30

# Admin Panel
ADMIN_PORT=3050  # Port for web admin panel
ADMIN_BASE_URL=http://localhost:3050  # Admin panel URL (for links)
