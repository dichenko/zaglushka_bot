<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel - TG Bots</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body { padding-top: 20px; }
.sidebar { min-height: 100vh; background: #f8f9fa; }
.nav-link.active { background: #0d6efd; color: white; }
</style>
</head>
<body>
<div class="container-fluid">
<div class="row">
<div class="col-md-2 sidebar p-3">
  <h5>Admin Panel</h5><hr>
  <ul class="nav flex-column">
    <li class="nav-item"><a class="nav-link" href="/admin/prompt">System Prompt</a></li>
    <li class="nav-item"><a class="nav-link" href="/admin/first-message">First Message</a></li>
    <li class="nav-item"><a class="nav-link active" href="/admin/bots">TG Bots</a></li>
    <li class="nav-item"><a class="nav-link" href="/admin/conversations">Conversations</a></li>
    <li class="nav-item mt-3"><a class="nav-link text-danger" href="/admin/logout">Logout</a></li>
  </ul>
</div>
<div class="col-md-10 p-4">
<h2>TG Bots</h2><hr>

<div class="card mb-4">
  <div class="card-body">
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addBotModal">Add New Bot</button>
    <div class="alert alert-warning mt-3">
      <strong>Note:</strong> After adding or modifying bots, restart Docker for changes to take effect:
      <code>docker compose restart app</code>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <table class="table table-striped">
      <thead><tr><th>ID</th><th>Token</th><th>Bot Link</th><th>Name</th><th>Status</th><th>Actions</th></tr></thead>
      <tbody id="botsTableBody">
        <tr><td colspan="6" class="text-center">Loading...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<div class="modal fade" id="addBotModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add New Bot</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="addBotForm">
          <div class="mb-3">
            <label for="botToken" class="form-label">Bot Token</label>
            <input type="text" class="form-control" id="botToken" required>
          </div>
          <div class="mb-3">
            <label for="botName" class="form-label">Bot Name (optional)</label>
            <input type="text" class="form-control" id="botName">
          </div>
          <button type="submit" class="btn btn-primary">Add Bot</button>
        </form>
      </div>
    </div>
  </div>
</div>

</div></div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function loadBots() {
  try {
    var response = await fetch('/api/admin/bots');
    var data = await response.json();
    if (data.success) {
      var tbody = document.getElementById('botsTableBody');
      if (data.bots.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center">No bots configured</td></tr>';
      } else {
        tbody.innerHTML = data.bots.map(function(bot) {
          return '<tr>' +
            '<td>' + bot.id + '</td>' +
            '<td><code>' + bot.token.substring(0, 10) + '...' + bot.token.substring(bot.token.length - 5) + '</code></td>' +
            '<td>' + (bot.bot_link ? '<a href="' + bot.bot_link + '" target="_blank">' + bot.bot_link + '</a>' : 'Not set') + '</td>' +
            '<td>' + (bot.bot_name || '-') + '</td>' +
            '<td>' + (bot.is_active ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-danger">Inactive</span>') + '</td>' +
            '<td><button class="btn btn-sm btn-danger" onclick="deleteBot(' + bot.id + ')">Delete</button></td>' +
          '</tr>';
        }).join('');
      }
    }
  } catch (e) {
    console.error('Failed to load bots:', e);
  }
}

document.getElementById('addBotForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  var token = document.getElementById('botToken').value.trim();
  var botName = document.getElementById('botName').value.trim();
  
  if (!token) return;

  try {
    var response = await fetch('/api/admin/bots', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: token, botName: botName })
    });
    var data = await response.json();
    if (data.success) {
      alert('Bot added! Restart Docker to apply changes.');
      loadBots();
      var modal = bootstrap.Modal.getInstance(document.getElementById('addBotModal'));
      if (modal) modal.hide();
      document.getElementById('addBotForm').reset();
    } else {
      alert('Error: ' + data.error);
    }
  } catch (e) {
    alert('Failed to add bot');
    console.error(e);
  }
});

async function deleteBot(id) {
  if (!confirm('Are you sure you want to delete this bot?')) return;
  try {
    var response = await fetch('/api/admin/bots/' + id, { method: 'DELETE' });
    var data = await response.json();
    if (data.success) {
      alert('Bot deleted! Restart Docker to apply changes.');
      loadBots();
    } else {
      alert('Error: ' + data.error);
    }
  } catch (e) {
    alert('Failed to delete bot');
  }
}

loadBots();
</script>
</body>
</html>
