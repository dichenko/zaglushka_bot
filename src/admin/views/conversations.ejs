<!DOCTYPE html>
<html lang="ru">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel - Conversations</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>body{padding-top:20px}.sidebar{min-height:100vh;background:#f8f9fa}.nav-link.active{background:#0d6efd;color:white}</style>
</head>
<body>
<div class="container-fluid"><div class="row">
<div class="col-md-2 sidebar p-3">
<h5>Admin Panel</h5><hr><ul class="nav flex-column">
<li class="nav-item"><a class="nav-link" href="/admin/prompt">System Prompt</a></li>
<li class="nav-item"><a class="nav-link" href="/admin/first-message">First Message</a></li>
<li class="nav-item"><a class="nav-link" href="/admin/bots">TG Bots</a></li>
<li class="nav-item"><a class="nav-link active" href="/admin/conversations">Conversations</a></li>
<li class="nav-item mt-3"><a class="nav-link text-danger" href="/admin/logout">Logout</a></li>
</ul></div>
<div class="col-md-10 p-4">
<h2>Conversations</h2><hr>
<div class="card mb-4"><div class="card-body">
<form id="filterForm" class="row g-3">
<div class="col-md-3"><label for="tgIdFilter" class="form-label">TG ID</label><input type="number" class="form-control" id="tgIdFilter" placeholder="Filter by TG ID"></div>
<div class="col-md-3"><label for="dateFrom" class="form-label">Date From</label><input type="date" class="form-control" id="dateFrom"></div>
<div class="col-md-3"><label for="dateTo" class="form-label">Date To</label><input type="date" class="form-control" id="dateTo"></div>
<div class="col-md-3 d-flex align-items-end"><button type="submit" class="btn btn-primary me-2">Filter</button><button type="button" class="btn btn-secondary" onclick="resetFilters()">Reset</button></div>
</form></div></div>
<div class="card"><div class="card-body">
<table class="table table-striped"><thead><tr><th>Date/Time</th><th>TG ID</th><th>Bot</th><th>Status</th><th>Started</th><th>Updated</th><th>Actions</th></tr></thead>
<tbody id="conversationsTableBody"><tr><td colspan="7" class="text-center">Loading...</td></tr></tbody></table>
<nav><ul class="pagination justify-content-center" id="pagination"></ul></nav>
<div class="text-center"><select class="form-select d-inline-block w-auto" id="pageSize" onchange="changePageSize()"><option value="20">20 per page</option><option value="50">50 per page</option><option value="100">100 per page</option></select></div>
</div></div>
</div></div></div>
<div class="modal fade" id="messageModal" tabindex="-1"><div class="modal-dialog modal-lg"><div class="modal-content">
<div class="modal-header"><h5 class="modal-title">Conversation Details</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body" id="messageModalBody">Loading...</div></div></div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
let currentPage=1,currentPageSize=20,currentFilters={}
async function loadConversations(page){try{const p=new URLSearchParams({page:page.toString(),limit:currentPageSize.toString(),...currentFilters});const r=await fetch('/api/admin/conversations?'+p);const d=await r.json();if(d.success){renderConversations(d.conversations);renderPagination(d.total,page)}}catch(e){console.error(e)}}
function renderConversations(c){const tb=document.getElementById('conversationsTableBody');if(c.length===0){tb.innerHTML='<tr><td colspan="7" class="text-center">No conversations found</td></tr>';return}tb.innerHTML=c.map(x=>{const s=x.status==='active'?'bg-success':x.status==='escalated'?'bg-warning':'bg-secondary';return'<tr><td>'+new Date(x.updated_at).toLocaleString()+'</td><td><a href="#" onclick="filterByTgId('+x.tg_id+');return false">'+x.tg_id+'</a></td><td>'+(x.bot_link||'-')+'</td><td><span class="badge '+s+'">'+x.status+'</span></td><td>'+new Date(x.started_at).toLocaleString()+'</td><td>'+new Date(x.updated_at).toLocaleString()+'</td><td><button class="btn btn-sm btn-info" onclick="viewConversation(\''+x.id+'\')">View</button></td></tr>'}).join('')}
function renderPagination(total,cp){const tp=Math.ceil(total/currentPageSize),pg=document.getElementById('pagination');let h='';h+='<li class="page-item '+(cp===1?'disabled':'')+'"><a class="page-link" href="#" onclick="loadConversations('+(cp-1)+')">Previous</a></li>';for(let i=1;i<=Math.min(tp,10);i++)h+='<li class="page-item '+(i===cp?'active':'')+'"><a class="page-link" href="#" onclick="loadConversations('+i+')">'+i+'</a></li>';h+='<li class="page-item '+(cp===tp?'disabled':'')+'"><a class="page-link" href="#" onclick="loadConversations('+(cp+1)+')">Next</a></li>';pg.innerHTML=h}
function filterByTgId(tgId){document.getElementById('tgIdFilter').value=tgId;currentFilters={tgId:tgId.toString()};currentPage=1;loadConversations(1)}
function resetFilters(){document.getElementById('filterForm').reset();currentFilters={};currentPage=1;loadConversations(1)}
function changePageSize(){currentPageSize=parseInt(document.getElementById('pageSize').value);currentPage=1;loadConversations(1)}
async function viewConversation(id){const m=new bootstrap.Modal(document.getElementById('messageModal'));m.show();try{const r=await fetch('/api/admin/conversations/'+id+'/messages');const d=await r.json();if(d.success){document.getElementById('messageModalBody').innerHTML=d.messages.map(x=>{const rb=x.role==='user'?'bg-primary':x.role==='assistant'?'bg-success':'bg-secondary';const c=x.transcription||x.content;return'<div class="mb-3"><span class="badge '+rb+'">'+x.role+'</span> <small class="text-muted">'+new Date(x.created_at).toLocaleString()+'</small>'+(x.message_type==='voice'?' <span class="badge bg-warning">VOICE</span>':'')+(x.tool_calls?' <span class="badge bg-info">TOOL CALL</span>':'')+'<div class="mt-1 p-2 bg-light rounded">'+c.replace(/</g,'&lt;').replace(/>/g,'&gt;')+'</div></div>'}).join('')}}catch(e){document.getElementById('messageModalBody').innerHTML='<div class="alert alert-danger">Failed to load messages</div>'}}
document.getElementById('filterForm').addEventListener('submit',(e)=>{e.preventDefault();currentFilters={};const tgId=document.getElementById('tgIdFilter').value;if(tgId)currentFilters.tgId=tgId;const df=document.getElementById('dateFrom').value;if(df)currentFilters.dateFrom=df;const dt=document.getElementById('dateTo').value;if(dt)currentFilters.dateTo=dt;currentPage=1;loadConversations(1)})
loadConversations(1)
</script>
</body></html>
