<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Panel - <%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { padding-top: 20px; }
    .sidebar { min-height: 100vh; background: #f8f9fa; }
    .nav-link.active { background: #0d6efd; color: white; }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 sidebar p-3">
        <h5>Admin Panel</h5>
        <hr>
        <ul class="nav flex-column">
          <li class="nav-item">
            <a class="nav-link <%= title === 'System Prompt' ? 'active' : '' %>" href="/admin/prompt">System Prompt</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'First Message' ? 'active' : '' %}" href="/admin/first-message">First Message</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Telegram Bots' ? 'active' : '' %>" href="/admin/bots">TG Bots</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= title === 'Conversation History' ? 'active' : '' %}" href="/admin/conversations">Conversations</a>
          </li>
          <li class="nav-item mt-3">
            <a class="nav-link text-danger" href="/admin/logout">Logout</a>
          </li>
        </ul>
      </div>
      <div class="col-md-10 p-4">
        <h2><%= title %></h2>
        <hr>
        <%- body %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
