<!DOCTYPE html>
<html lang="ru">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Panel - System Prompt</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>body{padding-top:20px}.sidebar{min-height:100vh;background:#f8f9fa}.nav-link.active{background:#0d6efd;color:white}</style>
</head>
<body>
<div class="container-fluid"><div class="row">
<div class="col-md-2 sidebar p-3">
<h5>Admin Panel</h5><hr><ul class="nav flex-column">
<li class="nav-item"><a class="nav-link active" href="/admin/prompt">System Prompt</a></li>
<li class="nav-item"><a class="nav-link" href="/admin/first-message">First Message</a></li>
<li class="nav-item"><a class="nav-link" href="/admin/bots">TG Bots</a></li>
<li class="nav-item"><a class="nav-link" href="/admin/conversations">Conversations</a></li>
<li class="nav-item mt-3"><a class="nav-link text-danger" href="/admin/logout">Logout</a></li>
</ul></div>
<div class="col-md-10 p-4">
<h2>System Prompt</h2><hr>
<div class="card"><div class="card-body">
<form id="promptForm">
<div class="mb-3">
<label for="promptText" class="form-label">System Prompt</label>
<textarea class="form-control" id="promptText" name="promptText" rows="20" required></textarea>
<div class="form-text">This prompt is sent to LLM with every request. Changes apply immediately.</div>
</div>
<div class="mb-3"><button type="submit" class="btn btn-primary">Save Prompt</button></div>
</form>
<div id="versionInfo" class="text-muted mt-3"></div>
</div></div>
</div></div></div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
async function loadPrompt(){
const r=await fetch('/api/admin/prompt');const d=await r.json();
if(d.success){document.getElementById('promptText').value=d.prompt
document.getElementById('versionInfo').textContent='Version: '+d.version+' | Updated: '+new Date(d.createdAt).toLocaleString()}}
document.getElementById('promptForm').addEventListener('submit',async(e)=>{e.preventDefault()
const r=await fetch('/api/admin/prompt',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({prompt:document.getElementById('promptText').value})})
const d=await r.json();if(d.success){alert('Prompt saved!');loadPrompt()}else{alert('Error: '+d.error)}})
loadPrompt()
</script>
</body></html>
